# Copia este archivo como .env.production y pon la IP pública de tu EC2
# IMPORTANTE: este archivo NO debe subirse a git (ya está en .gitignore)

# URL de la API en EC2 — sin barra al final
# Ejemplo con IP:         http://54.123.45.67:4000
# Ejemplo con dominio:    https://api.tudominio.com
REACT_APP_API_BASE=http://<IP-PUBLICA-EC2>:4000
